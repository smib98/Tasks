{
  "name": "notetasks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/run-with-config.mjs next dev",
    "build": "node scripts/run-with-config.mjs prisma generate && node scripts/run-with-config.mjs next build",
    "start": "node scripts/run-with-config.mjs next start",
    "start:https": "node scripts/run-with-config.mjs node scripts/https-server.mjs",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "node scripts/run-with-config.mjs prisma generate",
    "db:migrate": "node scripts/ensure-database.mjs && node scripts/run-with-config.mjs prisma migrate dev",
    "db:push": "node scripts/ensure-database.mjs && node scripts/run-with-config.mjs prisma db push",
    "db:seed": "node scripts/run-with-config.mjs prisma db seed",
    "db:demo": "node scripts/run-with-config.mjs tsx prisma/demo-seed.ts",
    "setup:whisper": "python3 -m venv .venv && .venv/bin/python -m pip install --upgrade pip && .venv/bin/python -m pip install -r requirements.txt",
    "setup:https": "node scripts/create-local-cert.mjs",
    "generate:pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "test:api": "tsx scripts/check-api.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.11.0",
    "@prisma/client": "^6.19.3",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.5.2",
    "dotenv": "^17.4.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.5.16",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1"
  },
  "engines": {
    "node": ">=22"
  },
  "overrides": {
    "next": {
      "postcss": "^8.5.18"
    }
  }
}
